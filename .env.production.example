# Production environment — copy to your host (Vercel, etc.)
# Do NOT commit real secrets to git.

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Live site URL
SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Note: NEXT_PUBLIC_* are read at container start on Docker (runtime-env.js).
# You do NOT need "Available at Buildtime" in Coolify — runtime env is enough.

# Admin access (comma-separated, must match signed-in user emails)
ADMIN_EMAILS=you@example.com

# Optional contact info shown on site
NEXT_PUBLIC_CONTACT_EMAIL=hello@your-domain.com
NEXT_PUBLIC_CONTACT_PHONE=
