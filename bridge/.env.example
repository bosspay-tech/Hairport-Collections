# ── BossPay Bridge ──────────────────────────────────────────────────
# Secret shared with BossPay (they provide this)
BOSSPAY_BRIDGE_SECRET=

# Public HTTPS URL where the site is reachable (no trailing slash)
# e.g. https://www.hairportcollections.com
BRIDGE_BASE_URL=

# Optional — defaults to https://api.bosspay24.com
# BOSSPAY_API_BASE=https://api.bosspay24.com

# ── Supabase (server-side, service role) ────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── SabPaisa credentials ───────────────────────────────────────────
SABPAISA_CLIENT_CODE=
SABPAISA_USERNAME=
SABPAISA_PASSWORD=
SABPAISA_AUTH_KEY=
SABPAISA_AUTH_IV=

# 'uat' | 'stag' | 'prod'
SABPAISA_ENV=stag

# ── Server ──────────────────────────────────────────────────────────
PORT=3000

# ── Vite build args (for Docker build) ─────────────────────────────
# These are passed as Docker build args to build the React frontend
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SABPAISA_CLIENT_CODE=
VITE_SABPAISA_USERNAME=
VITE_SABPAISA_PASSWORD=
VITE_SABPAISA_AUTHENTICATION_KEY=
VITE_SABPAISA_AUTHENTICATION_IV=
VITE_SABPAISA_ENV=
