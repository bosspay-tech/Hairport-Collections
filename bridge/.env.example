# ── BossPay Bridge ──────────────────────────────────────────────────
# Secret shared with BossPay (they provide this)
BOSSPAY_BRIDGE_SECRET=

# Public HTTPS URL where this bridge is reachable (no trailing slash)
# e.g. https://bridge.hairport-collections.com
BRIDGE_BASE_URL=

# Optional — defaults to https://api.bosspay24.com
# BOSSPAY_API_BASE=https://api.bosspay24.com

# ── Supabase (server-side, service role) ────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── SabPaisa credentials ───────────────────────────────────────────
SABPAISA_CLIENT_CODE=
SABPAISA_USERNAME=
SABPAISA_PASSWORD=
SABPAISA_AUTH_KEY=
SABPAISA_AUTH_IV=

# 'uat' | 'stag' | 'prod'
SABPAISA_ENV=stag

# ── Frontend ────────────────────────────────────────────────────────
# Where to redirect customers after payment (your storefront URL)
FRONTEND_URL=https://hairport-collections.com

# ── Server ──────────────────────────────────────────────────────────
PORT=3000
