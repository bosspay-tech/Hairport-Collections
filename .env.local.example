# New Supabase project (storefront)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: database password to auto-apply schema (Settings → Database)
SUPABASE_DB_PASSWORD=your_database_password

# Old Supabase (only for one-time product migration)
OLD_SUPABASE_URL=https://old-project.supabase.co
OLD_SUPABASE_SERVICE_ROLE_KEY=your_old_service_role_key

SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated emails allowed to access /admin (must match a signed-in user)
ADMIN_EMAILS=you@example.com
